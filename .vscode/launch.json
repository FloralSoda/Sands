{
	// Use IntelliSense to learn about possible attributes.
	// Hover to view descriptions of existing attributes.
	// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
	"version": "0.2.0",
	"configurations": [
		{
			"type": "lldb",
			"request": "launch",
			"name": "Sands Debug",
			"cargo": {
				"args": [
					"build",
					"--bin=sands",
					"--package=sands"
				],
				"filter": {
					"name": "sands",
					"kind": "bin"
				}
			},
			"args": [
				"-vdebug"
			],
			"cwd": "${workspaceFolder}"
		},
		{
			"type": "lldb",
			"request": "launch",
			"name": "Sands Unit Tests",
			"cargo": {
				"args": [
					"test",
					"--no-run",
					"--bin=sands",
					"--package=sands"
				],
				"filter": {
					"name": "sands",
					"kind": "bin"
				}
			},
			"args": [],
			"cwd": "${workspaceFolder}"
		},
		{
			"type": "lldb",
			"request": "launch",
			"name": "Toolbox Debug",
			"cargo": {
				"args": [
					"build",
					"--bin=sands",
					"--package=sands"
				],
				"filter": {
					"name": "sands",
					"kind": "bin"
				}
			},
			"args": [
				"-t",
				"-vdebug"
			],
			"cwd": "${workspaceFolder}"
		}
	]
}
