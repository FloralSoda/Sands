code = "shader_type canvas_item;
render_mode blend_mix;

uniform float Strength : hint_range(256, 512, 2) = 256;
uniform sampler2D screen_tex_frg_7 : hint_screen_texture;



void fragment() {
// Input:2
	vec2 n_out2p0 = UV;


// FloatParameter:3
	float n_out3p0 = Strength;


// VectorOp:4
	vec2 n_out4p0 = n_out2p0 * vec2(n_out3p0);


// VectorFunc:5
	vec2 n_out5p0 = floor(n_out4p0);


// VectorOp:6
	vec3 n_out6p0 = vec3(n_out5p0, 0.0) / vec3(n_out3p0);


	vec4 n_out7p0;
// Texture2D:7
	n_out7p0 = texture(screen_tex_frg_7, vec2(n_out6p0.xy));


// Output:0
	COLOR.rgb = vec3(n_out7p0.xyz);


}
"
